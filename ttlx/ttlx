#!/usr/bin/env python3
import os
import sys
from groq import Groq

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))

def load_env(filepath=".env"):
    if os.path.exists(filepath):
        with open(filepath, "r") as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#"): continue
                if "=" in line:
                    key, value = line.split("=", 1)
                    os.environ[key.strip()] = value.strip().strip("'").strip('"')

def get_instructions(filepath=".instructions"):
    try:
        with open(filepath, "r", encoding="utf-8") as f:
            return f.read()
    except FileNotFoundError:
        print(f"Error: '{filepath}' not found. Please create it with your prompt instructions.")
        sys.exit(1)

# 1. Setup
load_env(os.path.join(SCRIPT_DIR, ".env"))
instructions = get_instructions(os.path.join(SCRIPT_DIR, ".instructions"))

if len(sys.argv) < 2:
    prog = os.path.basename(sys.argv[0]) or "ttlx"
    print(f"Usage: {prog} <filename>")
    sys.exit(1)

input_file = sys.argv[1]

# 2. Read user input
try:
    with open(input_file, "r", encoding="utf-8") as f:
        file_content = f.read()
except FileNotFoundError:
    print(f"Error: The file '{input_file}' was not found.")
    sys.exit(1)

# 3. Call Groq
client = Groq(api_key=os.environ.get("GROQ_API_KEY"))
full_prompt = f"{instructions}\n\n{file_content}"

try:
    completion = client.chat.completions.create(
        messages=[{"role": "user", "content": full_prompt}],
        model="llama-3.3-70b-versatile",
    )

    # 4. Save to .tex
    base_name = os.path.splitext(input_file)[0]
    output_filename = f"{base_name}.tex"

    with open(output_filename, "w", encoding="utf-8") as f:
        f.write(completion.choices[0].message.content)
    
    print(f"--- Success! Output written to {output_filename} ---")

except Exception as e:
    print(f"API Error: {e}")
