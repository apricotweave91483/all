#!/usr/bin/env python3
import argparse
import re
import sys
from pathlib import Path


COMPARATORS = {
    "icmp": {
        "description": "Compare two int values for qsort/bsearch.",
        "code": """int icmp(const void *a, const void *b) {
    const int lhs = *(const int *)a;
    const int rhs = *(const int *)b;
    return (lhs > rhs) - (lhs < rhs);
}""",
    },
    "llcmp": {
        "description": "Compare two long long values for qsort/bsearch.",
        "code": """int llcmp(const void *a, const void *b) {
    const long long lhs = *(const long long *)a;
    const long long rhs = *(const long long *)b;
    return (lhs > rhs) - (lhs < rhs);
}""",
    },
}


def parse_args() -> argparse.Namespace:
    helper_lines = [
        f"  - {name}: {meta['description']}" for name, meta in sorted(COMPARATORS.items())
    ]
    helper_text = "Available helpers:\n" + "\n".join(helper_lines)
    parser = argparse.ArgumentParser(
        description="Inject canned helper functions into a C source file.",
        epilog=helper_text,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("source", help="Input C file path")
    parser.add_argument("helpers", nargs="+", help="Helper names to inject")
    parser.add_argument(
        "-o",
        "--output",
        help="Output file path (default: overwrite input source)",
    )
    return parser.parse_args()


def include_insert_index(text: str) -> int:
    include_pattern = re.compile(
        r"^\s*#\s*include\s*[<\"].*[>\"]\s*(?://.*)?$",
        re.MULTILINE,
    )
    matches = list(include_pattern.finditer(text))
    if not matches:
        return 0
    return matches[-1].end()


def function_already_present(text: str, name: str) -> bool:
    signature = re.compile(rf"\b{name}\s*\(\s*const\s+void\s*\*\s*\w*\s*,")
    return bool(signature.search(text))


def build_insertion_block(source_text: str, helper_names: list[str]) -> str:
    missing = []
    for helper_name in helper_names:
        if helper_name not in COMPARATORS:
            valid = ", ".join(sorted(COMPARATORS.keys()))
            raise ValueError(f"Unknown helper '{helper_name}'. Valid helpers: {valid}")
        if function_already_present(source_text, helper_name):
            continue
        missing.append(COMPARATORS[helper_name]["code"])

    if not missing:
        return ""
    return "\n\n" + "\n\n".join(missing) + "\n"


def inject_helpers(source_text: str, helper_names: list[str]) -> str:
    insertion = build_insertion_block(source_text, helper_names)
    if not insertion:
        return source_text

    idx = include_insert_index(source_text)
    if idx == 0:
        return insertion.lstrip("\n") + "\n" + source_text

    return source_text[:idx] + insertion + source_text[idx:]


def main() -> int:
    args = parse_args()
    source_path = Path(args.source)
    output_path = Path(args.output) if args.output else source_path

    if not source_path.exists():
        print(f"Error: source file not found: {source_path}", file=sys.stderr)
        return 1

    source_text = source_path.read_text(encoding="utf-8")
    try:
        result_text = inject_helpers(source_text, args.helpers)
    except ValueError as err:
        print(f"Error: {err}", file=sys.stderr)
        return 2

    output_path.write_text(result_text, encoding="utf-8")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
